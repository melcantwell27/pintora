# ═══════════════════════════════════════════════════════════════════
# TEMPLATE ONLY — safe to commit. Do NOT put real secrets here.
#
# Edit backend/.env instead (gitignored). First-time setup copies this
# file for you:  bash scripts/setup.sh
# ═══════════════════════════════════════════════════════════════════

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (must match docker-compose / root .env)
# Host port is 5434 to avoid clashing with other local Postgres instances.
POSTGRES_DB=pintora
POSTGRES_USER=pintora
POSTGRES_PASSWORD=pintora
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# CORS / CSRF — Next.js dev server (port 3001 to avoid clashes)
CORS_ALLOWED_ORIGINS=http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001

# Frontend origin (used for allauth email/verification links back to the SPA)
FRONTEND_ORIGIN=http://localhost:3001

# Google OAuth — get these from Google Cloud Console → Auth Platform → Clients.
# Authorized redirect URI: http://localhost:8001/api/auth/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
